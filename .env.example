# =============================================================================
# .env.example — copy to .env and replace every <CHANGE_ME_...> before use.
#
#   cp .env.example .env
#   export HOST_PROJECT_PATH=$PWD
#
# Generate a strong secret (use for *_PASSWORD, *_SECRET):
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#
# Generate an exactly-32-character key (used only for HOPP_ENCRYPTION_KEY):
#   python3 -c "import secrets,string; a=string.ascii_letters+string.digits; print(''.join(secrets.choice(a) for _ in range(32)))"
#
# Never commit .env to version control — it is already in .gitignore.
# =============================================================================

# ── Required: host path so worker containers can mount volumes correctly ──────
# Docker bind mounts inside scan.sh are resolved by the host's Docker daemon,
# not the worker container's filesystem, so this must be the *host* path to
# this repo. Set it before every `docker compose up`:
#   export HOST_PROJECT_PATH=$PWD
HOST_PROJECT_PATH=/path/to/mste

# ── PostgreSQL ────────────────────────────────────────────────────────────────
WEB_DB_USER=mste_user
WEB_DB_PASSWORD=<CHANGE_ME_strong_db_password>

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<CHANGE_ME_strong_redis_password>

# ── FastAPI backend ───────────────────────────────────────────────────────────
# JWT_SECRET must be at least 32 characters — the API refuses to start
# otherwise (see api/config.py jwt_secret_min_length validator).
JWT_SECRET=<CHANGE_ME_random_secret_min_32_chars>
# Password for the auto-created 'admin' account on first boot.
ADMIN_PASSWORD=<CHANGE_ME_strong_admin_password>

# ── ZAP ───────────────────────────────────────────────────────────────────────
ZAP_API_KEY=<CHANGE_ME_random_secret_min_32_chars>

# ── MobSF (mobile scanning) ───────────────────────────────────────────────────
# Get this key from the MobSF web UI (http://localhost:8008) under
# API Docs after first login. Falls back to a placeholder if unset, but
# mobile scans will fail authentication against MobSF until this is set
# to match what's configured in the MobSF container itself.
MOBSF_API_KEY=<CHANGE_ME_mobsf_api_key>

# ── Public domain (used to build CORS_ORIGINS for the API) ───────────────────
# Defaults to "localhost" if unset — fine for local dev, must be your real
# domain for any non-local deployment so the API accepts requests from the
# frontend's actual origin.
DOMAIN=localhost

# ── Hoppscotch (optional — API testing tool bundled for convenience) ─────────
HOPP_DB_USER=hopp_user
HOPP_DB_PASSWORD=<CHANGE_ME_strong_hopp_db_password>
HOPP_JWT_SECRET=<CHANGE_ME_random_secret_min_48_chars>
HOPP_SESSION_SECRET=<CHANGE_ME_random_secret_min_48_chars>
# Must be exactly 32 characters — Hoppscotch validates this strictly.
HOPP_ENCRYPTION_KEY=<CHANGE_ME_exactly_32_chars_here_xx>
# Your server's public domain or IP, with scheme:
HOPPSCOTCH_ORIGIN=https://your-server-domain.com
